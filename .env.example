# phenoEvents observability — env vars
# Set OTEL_EXPORTER_OTLP_ENDPOINT to a running otel/opentelemetry-collector-contrib
# instance. Spans are exported to gRPC port 4317.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=pheno-events
OTEL_RESOURCE_ATTRIBUTES=service.namespace=phenoEvents,deployment.environment=local
RUST_LOG=info,pheno_events=debug,phenoevents_observability=debug
